# ============================================================================
# NodePass License Center 环境变量配置
# ============================================================================

# PostgreSQL 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nodepass_license
POSTGRES_PORT=5432

# 应用配置
APP_PORT=8090
BUILD_VERSION=0.3.0
GIN_MODE=release

# 可选：外部数据库连接（如果使用外部数据库，注释掉上面的 POSTGRES_* 配置）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 可选：Redis 配置（如果启用 Redis）
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
