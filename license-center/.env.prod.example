# ============================================================================
# 生产环境配置 - 使用预构建镜像
# ============================================================================

# PostgreSQL 配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nodepass_license
POSTGRES_PORT=5432

# 应用配置
APP_PORT=8090
BUILD_VERSION=0.3.0
GIN_MODE=release

# 镜像配置
IMAGE_NAME=nodepass/license-center
# REGISTRY=registry.example.com  # 如果使用私有仓库，取消注释并设置

# 可选：外部数据库连接（如果使用外部数据库，注释掉上面的 POSTGRES_* 配置）
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# 可选：Redis 配置（如果启用 Redis）
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
