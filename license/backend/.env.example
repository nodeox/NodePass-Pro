# Server
SERVER_PORT=8091
GIN_MODE=debug

# Database: sqlite / mysql / postgres
DB_DRIVER=sqlite
DB_DSN=./data/license-unified.db

# JWT
JWT_SECRET=please-change-this-secret
JWT_EXPIRE_HOURS=24

# Bootstrap admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# 必填：请设置强密码
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_RESET_ADMIN_PASSWORD=false

# Payment callback signature verify
# 如果 strict=true 且对应渠道未配置密钥，将拒绝回调
PAYMENT_CALLBACK_STRICT=false
PAYMENT_CALLBACK_TOLERANCE_SECONDS=300
PAYMENT_CALLBACK_SECRET_DEFAULT=
PAYMENT_CALLBACK_SECRET_MANUAL=
PAYMENT_CALLBACK_SECRET_ALIPAY=
PAYMENT_CALLBACK_SECRET_WECHAT=

# Release package upload
RELEASE_UPLOAD_DIR=./uploads/releases
