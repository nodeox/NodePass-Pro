# Web 访问端口（宿主机）
PANEL_PORT=8088
# 绑定域名（可选，配置后可配合 docker-compose.domain.yml 自动反向代理）
PANEL_DOMAIN=
# 证书邮箱（可选，建议填写；用于 HTTPS 证书到期通知）
ACME_EMAIL=
# 是否在目标机器本地编译（默认 false，拉取镜像部署）
DEPLOY_WITH_BUILD=false
# 镜像拉取失败时，是否自动回退为源码编译部署（默认 true）
AUTO_BUILD_FALLBACK=true

# 必填：JWT 密钥（建议 32+ 位随机串）
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_HOURS=24

# 必填：首次启动管理员密码
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-this-admin-password
BOOTSTRAP_RESET_ADMIN_PASSWORD=false

# 后端运行模式
GIN_MODE=release

# 数据库（默认 sqlite）
DB_DRIVER=sqlite
DB_DSN=/app/data/license-unified.db

# 版本安装包目录
RELEASE_UPLOAD_DIR=/app/uploads/releases

# 支付回调签名（可选）
PAYMENT_CALLBACK_STRICT=false
PAYMENT_CALLBACK_TOLERANCE_SECONDS=300
PAYMENT_CALLBACK_SECRET_DEFAULT=
PAYMENT_CALLBACK_SECRET_MANUAL=
PAYMENT_CALLBACK_SECRET_ALIPAY=
PAYMENT_CALLBACK_SECRET_WECHAT=
