# NodePass Pro 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# JWT 配置（必须）
# ============================================
# JWT 密钥：用于签名和验证 JWT token
# 要求：至少 32 字符（推荐 64 字符以上）
# 生成方法：openssl rand -base64 48
# 警告：生产环境必须使用强随机密钥，不要使用示例值
JWT_SECRET=your-generated-secret-here-at-least-32-characters-long

# JWT 过期时间（小时）
JWT_EXPIRE_TIME=168

# ============================================
# 授权配置（可选）
# ============================================
# 是否启用授权验证
BACKEND_LICENSE_ENABLED=false

# 授权验证服务器 URL
LICENSE_VERIFY_URL=https://license.nodepass.pro/api/v1/license/verify

# 授权密钥
LICENSE_KEY=

# 机器 ID
LICENSE_MACHINE_ID=

# 面板访问域名（当 BACKEND_LICENSE_ENABLED=true 时，与 BACKEND_LICENSE_SITE_URL 至少配置一个）
# 示例：panel.example.com
BACKEND_LICENSE_DOMAIN=

# 面板完整访问地址（当 BACKEND_LICENSE_ENABLED=true 时，与 BACKEND_LICENSE_DOMAIN 至少配置一个）
# 示例：https://panel.example.com
BACKEND_LICENSE_SITE_URL=

# 授权验证间隔（秒）
BACKEND_LICENSE_VERIFY_INTERVAL=300

# 授权验证失败时是否允许继续运行
BACKEND_LICENSE_FAIL_OPEN=false

# 离线宽限期（秒）
BACKEND_LICENSE_OFFLINE_GRACE_SECONDS=600

# ============================================
# 前端配置（可选）
# ============================================
# 前端监听地址（默认：127.0.0.1:5173）
# 生产环境建议改为 0.0.0.0:5173 以允许外部访问
FRONTEND_BIND=127.0.0.1:5173

# ============================================
# 后端配置文件路径（可选）
# ============================================
# 自定义后端配置文件路径
# BACKEND_CONFIG_FILE=./backend/configs/config.docker.yaml

# ============================================
# 版本配置（可选）
# ============================================
# BACKEND_VERSION=dev
# FRONTEND_VERSION=dev
